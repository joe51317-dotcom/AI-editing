# === Auto-Process 課程影片自動剪輯設定 ===

# --- 靜音偵測 ---
SILENCE_NOISE_DB=-30              # 完全靜音判定閾值（備用，目前未使用於主流程）
SPEECH_THRESHOLD_DB=-20           # 講課語音門檻（低於此 dB 視為環境音/靜音）
SILENCE_MIN_DURATION=10           # 最短靜音秒數（開頭/結尾偵測用）
BREAK_THRESHOLD_SECONDS=300       # 中間休息判定秒數（預設 5 分鐘）

# --- YouTube 上傳 ---
YOUTUBE_CLIENT_SECRET=./credentials/client_secret.json
YOUTUBE_TOKEN_PATH=./credentials/token.json
YOUTUBE_DEFAULT_PRIVACY=unlisted  # unlisted / public / private
YOUTUBE_DEFAULT_CATEGORY=27       # 27 = Education

# --- 工作資料夾（相對於專案根目錄，通常不需改） ---
INBOX_DIR=./auto-process/inbox
PROCESSING_DIR=./auto-process/processing
DONE_DIR=./auto-process/done
FAILED_DIR=./auto-process/failed
LOG_DIR=./auto-process/logs
